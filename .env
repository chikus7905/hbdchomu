# 🌸 Birthday Bloom — Environment Configuration Template
# Copy this file to .env and change the values to personalize your surprise!

# 🆔 BIRTHDAY PERSON'S NAME
# The name of the person you're celebrating. 
# Resolution Priority: .env > src/config.ts > "YOU"
VITE_BIRTHDAY_NAME="Chømû 🐼"

# 🖼️ CUSTOM PHOTO URLS (Optional)
# If provided, these will override the local assets/photoX.jpg files.
# Use direct image links (e.g., from Unsplash, Imgur, or your own CDN).
VITE_PHOTO_1=""
VITE_PHOTO_2=""
VITE_PHOTO_3=""

# 🎵 CUSTOM BACKGROUND MUSIC (Optional)
# Direct link to an mp3/wav file.
VITE_SOUND_URL="https://res.cloudinary.com/dmw40bais/video/upload/v1775106445/Good_Luck_Charm_-_K_S_Makhan_h24kse.mp3"

# 🛠️ ADVANCED SETTINGS
# Set to 'true' to enable debug logs in the console
VITE_DEBUG_MODE="false"
